{
  "name": "employee-leave-absence-request-system",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack Employee Leave & Absence Request System",
  "scripts": {
    "dev": "concurrently \"yarn --cwd server dev\" \"yarn --cwd client dev\"",
    "dev:client": "yarn --cwd client dev",
